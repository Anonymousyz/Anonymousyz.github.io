---
interface Props {
  current?: 'home' | 'methods' | 'projects' | 'works' | 'about';
}

const { current } = Astro.props;
const methodNav = { key: 'methods', label: '方法', href: '/methods/' };
const currentPath = Astro.url.pathname;
const isMethodHub = currentPath === methodNav.href;
const methodItems = [
  { label: '持续学习', href: '/methods/learning/' },
  { label: '研究与判断', href: '/methods/research-and-judgment/' },
  { label: '多元思维', href: '/methods/plural-thinking/' },
  { label: '写作', href: '/methods/writing/' },
  { label: '产品定义', href: '/methods/product-definition/' },
  { label: '视觉信息设计', href: '/methods/visual-information-design/' },
  { label: '产品与工程', href: '/methods/product-and-engineering/' },
];
const navItems = [
  { key: 'projects', label: '项目', href: '/projects/' },
  { key: 'works', label: '公开作品', href: '/works/' },
  { key: 'about', label: '关于', href: '/about/' }
];
---

<header class="site-header shell">
  <a class="brand" href="/" aria-label="返回首页" aria-current={current === 'home' ? 'page' : undefined}>Anonymousyz</a>
  <nav class="desktop-nav" aria-label="主导航">
    <a
      class:list={{ active: current === 'methods' }}
      href={methodNav.href}
      aria-current={isMethodHub ? 'page' : undefined}
    >{methodNav.label}</a>
    {navItems.map((item) => (
      <a
        class:list={{ active: current === item.key }}
        href={item.href}
        aria-current={current === item.key ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>
  <details class="mobile-nav">
    <summary>菜单</summary>
    <nav aria-label="移动端主导航">
      <div class="mobile-nav__methods">
        <a class:list={{ active: current === 'methods' }} href={methodNav.href} aria-current={isMethodHub ? 'page' : undefined}>{methodNav.label}</a>
        <div class="mobile-nav__subnav">
          {methodItems.map((item) => <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>)}
        </div>
      </div>
      {navItems.map((item) => (
        <a
          class:list={{ active: current === item.key }}
          href={item.href}
          aria-current={current === item.key ? 'page' : undefined}
        >{item.label}</a>
      ))}
    </nav>
  </details>
</header>
<span id="main-content" class="main-content-anchor" tabindex="-1"></span>