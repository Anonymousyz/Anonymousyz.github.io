---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/portfolio.mjs';
---

<Layout
  title="项目与实践｜Anonymousyz"
  description="三个项目记录，说明我做了什么、项目进展到哪一步，以及哪些内容可以公开。"
  image="/og/projects.png"
>
  <SiteHeader current="projects" />

  <main>
    <section class="editorial-hero shell">
      <p class="editorial-eyebrow">项目</p>
      <h1>三个项目</h1>
      <p class="editorial-lead">三个项目分别做到可部署版本、内部功能版本和受控演示版。这里写清我的工作、当前进度和公开范围；界面只使用脱敏样例数据。</p>
    </section>

    <nav class="project-jump shell" aria-label="项目索引">
      {projects.map((project) => (
        <a href={`#${project.id}`}><span>{project.index}</span>{project.title}</a>
      ))}
    </nav>

    {projects.map((project) => (
      <section class="editorial-section shell project-detail" id={project.id}>
        <div class="project-detail-heading">
          <div>
            <p class="editorial-kicker">{project.index} / {project.pillar}</p>
            <h2>{project.title}</h2>
          </div>
          <p>{project.summary}</p>
        </div>

        <div class="project-facts">
          <article>
            <span>问题</span>
            <p>{project.problem}</p>
          </article>
          <article>
            <span>我的工作</span>
            <p>{project.role}</p>
          </article>
        </div>

        <div class="project-facts">
          <article>
            <span>关键做法</span>
            <ul>{project.decisions.map((item) => <li>{item}</li>)}</ul>
          </article>
          <article>
            <span>当前进度</span>
            <ul>{project.results.map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>

        {project.prototypeShowcase && (
          <section class="project-prototype-showcase" aria-labelledby={project.id + '-prototype-title'}>
            <div class="project-prototype-showcase__head">
              <div>
                <p class="editorial-kicker">{project.prototypeShowcase.status}</p>
                <h3 id={project.id + '-prototype-title'}>界面快照</h3>
              </div>
              <p>{project.prototypeShowcase.intro}</p>
            </div>
            {project.prototypeShowcase.presentation === 'featured-switcher' ? (
              <div class="project-prototype-showcase__switcher" data-prototype-switcher>
                <div class="project-prototype-showcase__tabs" role="tablist" aria-label="选择界面快照">
                  {project.prototypeShowcase.images.map((image, index) => {
                    const tabId = `${project.id}-prototype-tab-${index + 1}`;
                    const panelId = `${project.id}-prototype-panel-${index + 1}`;

                    return (
                      <button
                        class="project-prototype-showcase__tab"
                        id={tabId}
                        type="button"
                        role="tab"
                        aria-selected={index === 0 ? 'true' : 'false'}
                        aria-controls={panelId}
                        tabindex={index === 0 ? 0 : -1}
                        data-prototype-tab
                      >
                        <span>{String(index + 1).padStart(2, '0')}</span>
                        {image.label}
                      </button>
                    );
                  })}
                </div>

                <div class="project-prototype-showcase__panels">
                  {project.prototypeShowcase.images.map((image, index) => {
                    const tabId = `${project.id}-prototype-tab-${index + 1}`;
                    const panelId = `${project.id}-prototype-panel-${index + 1}`;

                    return (
                      <figure
                        class="project-prototype-showcase__item project-prototype-showcase__panel"
                        id={panelId}
                        role="tabpanel"
                        aria-labelledby={tabId}
                        hidden={index !== 0}
                        data-prototype-panel
                      >
                        <div class="project-prototype-showcase__stage">
                          <a href={image.src} aria-label={'查看' + image.label + '大图'}>
                            <span
                              class="project-prototype-showcase__viewport"
                              style={`--prototype-zoom: ${image.displayZoom ?? 1}; --prototype-focus: ${image.displayFocus ?? '50% 50%'}; --prototype-zoom-mobile: ${image.displayZoomMobile ?? image.displayZoom ?? 1}; --prototype-focus-mobile: ${image.displayFocusMobile ?? '56% 24%'};`}
                            >
                              <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" />
                            </span>
                          </a>
                        </div>
                        <figcaption>
                          <div class="project-prototype-showcase__description">
                            <strong>{image.label}</strong>
                            <p>{image.explanation}</p>
                          </div>
                          <small class="project-prototype-showcase__boundary">{image.boundary}</small>
                        </figcaption>
                      </figure>
                    );
                  })}
                </div>

                <noscript>
                  <p class="project-prototype-showcase__noscript">
                    {project.prototypeShowcase.images.map((image) => (
                      <a href={image.src}>查看{image.label}原图</a>
                    ))}
                  </p>
                </noscript>
              </div>
            ) : (
              <div class="project-prototype-showcase__grid">
                {project.prototypeShowcase.images.map((image) => (
                  <figure class="project-prototype-showcase__item">
                    <a href={image.src} aria-label={'查看' + image.label + '大图'}>
                      <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" />
                    </a>
                    <figcaption>
                      <div class="project-prototype-showcase__description">
                        <strong>{image.label}</strong>
                        <p>{image.explanation}</p>
                      </div>
                      <small class="project-prototype-showcase__boundary">{image.boundary}</small>
                    </figcaption>
                  </figure>
                ))}
              </div>
            )}
          </section>
        )}

        <div class="project-facts">
          <article>
            <span>工作路径</span>
            <p>{project.deliveryPath}</p>
          </article>
          <article>
            <span>公开内容</span>
            <ul>{project.publicScope.map((item) => <li>{item}</li>)}</ul>
          </article>
        </div>

        <div class="project-boundary">
          <strong>未公开内容</strong>
          <p>{project.boundary}</p>
        </div>
      </section>
    ))}
  </main>

  <script>
    document.querySelectorAll('[data-prototype-switcher]').forEach((switcher) => {
      const tabs = Array.from(switcher.querySelectorAll('[data-prototype-tab]'));
      const panels = Array.from(switcher.querySelectorAll('[data-prototype-panel]'));

      const activate = (nextTab, shouldFocus = false) => {
        const panelId = nextTab.getAttribute('aria-controls');

        tabs.forEach((tab) => {
          const isActive = tab === nextTab;
          tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          tab.setAttribute('tabindex', isActive ? '0' : '-1');
        });

        panels.forEach((panel) => {
          panel.toggleAttribute('hidden', panel.id !== panelId);
        });

        if (shouldFocus && nextTab instanceof HTMLElement) {
          nextTab.focus();
        }
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => activate(tab));
        tab.addEventListener('keydown', (event) => {
          let nextIndex = index;

          if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
          else if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
          else if (event.key === 'Home') nextIndex = 0;
          else if (event.key === 'End') nextIndex = tabs.length - 1;
          else return;

          event.preventDefault();
          activate(tabs[nextIndex], true);
        });
      });
    });
  </script>

  <SiteFooter />
</Layout>
