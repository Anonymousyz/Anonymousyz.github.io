---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="页面未找到｜Anonymousyz" description="请求的页面不存在。">
  <SiteHeader />
  <main>
    <section class="editorial-hero shell not-found-editorial">
      <p class="editorial-eyebrow">404</p>
      <h1>没有找到<br />这个页面</h1>
      <p class="editorial-lead">地址可能已经变更。你可以返回首页，或继续查看项目和公开作品。</p>
      <nav class="not-found-links" aria-label="页面未找到后的可选入口">
        <a class="text-link" href="/">返回首页</a>
        <a class="text-link" href="/projects/">查看项目</a>
        <a class="text-link" href="/works/">查看公开作品</a>
      </nav>
    </section>
  </main>
  <SiteFooter />
</Layout>
