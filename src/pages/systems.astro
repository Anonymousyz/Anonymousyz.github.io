---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="内容已迁移｜Anonymousyz" description="原页面内容已整合到项目页。">
  <SiteHeader />
  <main>
    <section class="editorial-hero shell">
      <p class="editorial-eyebrow">内容已迁移</p>
      <h1>请从项目页<br />继续阅读</h1>
      <p class="editorial-lead">旧地址仍然有效，原来的项目内容已经移到项目页。</p>
      <a class="text-link" href="/projects/">前往项目页 <span aria-hidden="true">→</span></a>
    </section>
  </main>
  <SiteFooter />
</Layout>
