---
import Layout from '../layouts/Layout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ToolProof from '../components/ToolProof.astro';
import { tools } from '../data/portfolio.mjs';

const softwareSchemas = tools.map((tool) => ({
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: tool.title,
  description: tool.summary,
  codeRepository: tool.href,
  ...(tool.version === '持续维护' ? {} : { version: tool.version }),
  ...(tool.runtime.startsWith('Python') ? { programmingLanguage: 'Python' } : {})
}));
---

<Layout
  title="公开作品｜Anonymousyz"
  description="四个公开仓库，提供研究、AI 系统上线前检查、资料索引和文档审阅工具。"
  image="/og/works.png"
  structuredData={softwareSchemas}
>
  <SiteHeader current="works" />

  <main>
    <section class="editorial-hero shell">
      <p class="editorial-eyebrow">公开作品</p>
      <h1>四个公开仓库</h1>
      <p class="editorial-lead">四个仓库分别用来整理研究材料、检查 AI 原型投入真实业务前还缺什么、查找工程和治理资料，以及给方案和技术文档做署名前审稿。每个仓库都列出版本、样例、使用方法和限制。</p>
    </section>

    <section class="editorial-section shell">
      <div class="tool-proof-list">
        {tools.map((tool) => <ToolProof tool={tool} />)}
      </div>
    </section>
  </main>

  <SiteFooter />
</Layout>
