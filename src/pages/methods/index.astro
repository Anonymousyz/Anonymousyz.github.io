---
import Layout from '../../layouts/Layout.astro';
import MethodIndex from '../../components/MethodIndex.astro';
import MethodRelationship from '../../components/MethodRelationship.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { methodRelationships, methodSystem } from '../../data/methods.mjs';
---

<Layout
  title="工作方法｜Anonymousyz"
  description="从决策问题、证据和写作，到产品、视觉和工程：我在实际工作中反复修订的方法。"
>
  <SiteHeader current="methods" />
  <main>
    <section class="editorial-hero article-shell method-hub-hero">
      <p class="editorial-eyebrow">从分析到决策 · 从技术到应用</p>
      <h1>工作方法</h1>
    </section>
    <section class="editorial-section article-shell method-hub" aria-labelledby="method-index-title">
      <h2 id="method-index-title" class="visually-hidden">方法索引</h2>
      <MethodRelationship relationships={methodRelationships} />
      <MethodIndex learning={methodSystem.learning} tracks={methodSystem.tracks} />
    </section>
  </main>
  <SiteFooter />
</Layout>
