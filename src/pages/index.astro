---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    index: '01',
    title: 'AI Prototype-to-Production Toolkit',
    description: '把“能运行的 AI Demo”转化为可审查的生产就绪判断：本地 CLI、否决门、治理工件与虚构案例。',
    tags: ['AI Readiness', 'GRC', 'Python CLI'],
    href: 'https://github.com/Anonymousyz/ai-prototype-to-production-toolkit'
  },
  {
    index: '02',
    title: 'Research-to-Decision Toolkit',
    description: '把资料堆积转化为可追溯的决策包：证据分级、反方审查、决策门与行动建议。',
    tags: ['Evidence', 'Decision Support', 'Red Team'],
    href: 'https://github.com/Anonymousyz/research-to-decision-toolkit'
  },
  {
    index: '03',
    title: 'Awesome AI Production Readiness',
    description: '面向 AI 评估、可观测性、护栏、治理、安全与部署的机器可读资源入口。',
    tags: ['Awesome List', 'Responsible AI', 'Resources'],
    href: 'https://github.com/Anonymousyz/awesome-ai-production-readiness'
  }
];

const principles = [
  {
    number: 'I',
    title: '证据先于结论',
    text: '区分事实、判断与假设，保留来源、版本和不可证明边界。'
  },
  {
    number: 'II',
    title: '边界先于功能',
    text: '先识别否决项、责任人和人工复核点，再讨论自动化与规模化。'
  },
  {
    number: 'III',
    title: '行动先于展示',
    text: '输出可执行的清单、评分卡、CLI 与决策门，而不是只交付观点。'
  }
];
---

<Layout
  title="Anonymousyz｜Applied AI · Governance · Decision Systems"
  description="连接 AI 治理、复杂研究与真实交付：公开工具、方法和可验证作品。"
>
  <header class="site-header shell">
    <a class="brand" href="#top" aria-label="返回首页">
      <span class="brand-mark">A</span>
      <span>Anonymousyz</span>
    </a>
    <nav aria-label="主导航">
      <a href="#work">作品</a>
      <a href="#method">方法</a>
      <a href="#about">关于</a>
    </nav>
    <a class="header-link" href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
      GitHub <span aria-hidden="true">↗</span>
    </a>
  </header>

  <main id="top">
    <section class="hero shell">
      <div class="hero-copy">
        <p class="eyebrow"><span></span> PUBLIC WORK / 2026</p>
        <h1>把复杂研究与 AI 治理，<br /><em>做成可以使用的工具。</em></h1>
        <p class="hero-lead">
          聚焦 Applied AI、Governance 与 Research-to-Decision。这里展示公开、可复用、可验证的工作成果。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#work">查看代表作品</a>
          <a class="button button-quiet" href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
            访问 GitHub <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <aside class="hero-panel" aria-label="工作关注点">
        <div class="panel-topline">
          <span>WORKING FOCUS</span>
          <span class="status"><i></i> OPEN SOURCE</span>
        </div>
        <div class="focus-list">
          <div><span>01</span><strong>AI 生产就绪</strong><small>Prototype → Production</small></div>
          <div><span>02</span><strong>治理与责任边界</strong><small>Governance · GRC</small></div>
          <div><span>03</span><strong>研究转化决策</strong><small>Evidence → Action</small></div>
        </div>
      </aside>
    </section>

    <section class="section shell" id="work">
      <div class="section-heading">
        <div>
          <p class="kicker">SELECTED WORK</p>
          <h2>代表作品</h2>
        </div>
        <p>不是项目陈列，而是把判断方法做成他人可以复用、检验和改进的公共工件。</p>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="card-index">{project.index}</div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul class="tag-list" aria-label="项目标签">
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>
            <a href={project.href} target="_blank" rel="noreferrer" aria-label={`查看 ${project.title}`}>
              查看仓库 <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section method-section" id="method">
      <div class="shell">
        <div class="section-heading light-heading">
          <div>
            <p class="kicker">WORKING METHOD</p>
            <h2>从判断到行动</h2>
          </div>
          <p>跨越研究、治理与工程的共同原则：可追溯、可复核、有边界。</p>
        </div>
        <div class="principle-grid">
          {principles.map((principle) => (
            <article class="principle">
              <span>{principle.number}</span>
              <h3>{principle.title}</h3>
              <p>{principle.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section shell about" id="about">
      <div>
        <p class="kicker">ABOUT</p>
        <h2>研究、治理与工程之间的连接者</h2>
      </div>
      <div class="about-copy">
        <p>
          我关注一个反复出现的问题：当 AI 从演示进入真实组织，哪些证据、边界和责任机制决定它能否被采用？
        </p>
        <p>
          因此，我把研究方法、治理要求和工程检查结合起来，做成可以复制、运行和审查的开放工具。
        </p>
        <a href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
          查看完整公开档案 <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell">
      <div>
        <strong>Anonymousyz</strong>
        <span>Applied AI · Governance · Decision Systems</span>
      </div>
      <p>Built in public. Evidence over claims.</p>
    </div>
  </footer>
</Layout>
