---
import Layout from '../layouts/Layout.astro';
import HomeMethodSystem from '../components/HomeMethodSystem.astro';
import ProjectIndex from '../components/ProjectIndex.astro';
import PublicWorkIndex from '../components/PublicWorkIndex.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { methodRelationships } from '../data/method-relationships.mjs';
import { demos, featuredCase, heroCopy, positioning, tools } from '../data/portfolio.mjs';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anonymousyz',
  url: 'https://decideandbuild.com/',
  sameAs: [
    'https://github.com/Anonymousyz'
  ]
};
---

<Layout
  title="Anonymousyz｜从分析到决策，从技术到应用"
  description="三个项目、七项工作方法和四个公开仓库，记录我怎样从分析走向决策、从技术走向应用。"
  image="/og/home.png"
  structuredData={personSchema}
>
  <SiteHeader current="home" />
  <main>
    <section class="editorial-hero shell">
      <p class="editorial-eyebrow">研究、项目与公开作品</p>
      <h1>{positioning[0]}<br />{positioning[1]}</h1>
      <p class="editorial-lead">{heroCopy}</p>
    </section>


    <section class="editorial-section shell" id="projects">
      <div class="editorial-section__head">
        <h2>代表项目</h2>
        <p>先看我做过什么，以及项目分别做到哪一步。</p>
      </div>
      <ProjectIndex {featuredCase} {demos} />
    </section>
    <section class="editorial-section shell" id="methods">
      <div class="editorial-section__head">
        <h2>两条工作主线</h2>
        <p>这些做法分成七项，分别写在方法页。</p>
      </div>
      <HomeMethodSystem relationships={methodRelationships} />
    </section>

    <section class="editorial-section shell" id="works">
      <div class="editorial-section__head">
        <h2>公开作品</h2>
        <p>四个仓库都可以直接查看；版本、样例和使用方法也在其中。</p>
      </div>
      <PublicWorkIndex works={tools} />
    </section>

  </main>
  <SiteFooter />
</Layout>
