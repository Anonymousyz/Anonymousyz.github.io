---
import Layout from '../layouts/Layout.astro';
import IdentityIndex from '../components/IdentityIndex.astro';
import MethodIndex from '../components/MethodIndex.astro';
import ProjectIndex from '../components/ProjectIndex.astro';
import PublicWorkIndex from '../components/PublicWorkIndex.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { identityProfiles, methodSystem } from '../data/methods.mjs';
import { demos, featuredCase, heroCopy, positioning, tools } from '../data/portfolio.mjs';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anonymousyz',
  url: 'https://decideandbuild.com/',
  sameAs: [
    'https://github.com/Anonymousyz'
  ]
};
---

<Layout
  title="Anonymousyz｜从分析到决策，从技术到应用"
  description="围绕“从分析到决策、从技术到应用”整理的个人方法、公开作品和项目记录。"
  image="/og/home.png"
  structuredData={personSchema}
>
  <SiteHeader current="home" />
  <main>
    <section class="editorial-hero shell">
      <p class="editorial-eyebrow">个人方法与项目实践</p>
      <h1>{positioning[0]}<br />{positioning[1]}</h1>
      <p class="editorial-lead">{heroCopy}</p>
    </section>

    <section class="editorial-section shell identity-section" id="identity" aria-labelledby="identity-title">
      <div class="editorial-section__head editorial-section__head--compact">
        <h2 id="identity-title">身份</h2>
      </div>
      <IdentityIndex identities={identityProfiles} />
    </section>

    <section class="editorial-section shell" id="methods">
      <div class="editorial-section__head">
        <h2>方法</h2>
        <p>七个入口，记录我在研究、写作和系统建设中的具体做法。</p>
      </div>
      <MethodIndex learning={methodSystem.learning} tracks={methodSystem.tracks} />
    </section>

    <section class="editorial-section shell" id="projects">
      <div class="editorial-section__head">
        <h2>项目</h2>
        <p>一个主案例，两份脱敏项目记录。</p>
      </div>
      <ProjectIndex {featuredCase} {demos} />
    </section>

    <section class="editorial-section shell" id="works">
      <div class="editorial-section__head">
        <h2>公开作品</h2>
        <p>我把工作中常用的研究和交付方法整理成了三个公开工具。</p>
      </div>
      <PublicWorkIndex works={tools} />
    </section>
  </main>
  <SiteFooter />
</Layout>
