---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    index: '01',
    question: 'AI Demo 已经能跑，离真正上线还差什么？',
    title: 'AI Prototype-to-Production Toolkit',
    description: '一个本地检查工具。它读取项目证据，给出生产就绪评分和否决项，帮助团队在演示之后继续往下走。最后的放行结论仍由人确认。',
    meta: '本地 CLI · 评分卡 · 否决项',
    href: 'https://github.com/Anonymousyz/ai-prototype-to-production-toolkit'
  },
  {
    index: '02',
    question: '资料很多，怎么整理成可以拍板的结论？',
    title: 'Research-to-Decision Toolkit',
    description: '把来源、反方意见、判断依据和行动建议放进同一个决策包，减少“材料不少，但下一步仍然说不清”的情况。',
    meta: '证据分级 · 反方审查 · 决策包',
    href: 'https://github.com/Anonymousyz/research-to-decision-toolkit'
  },
  {
    index: '03',
    question: '生产级 AI 需要补齐哪些能力？',
    title: 'Awesome AI Production Readiness',
    description: '一份持续维护的公开资源清单，按评估、可观测性、护栏、治理、安全和部署分类，便于按问题查找工具和资料。',
    meta: '资源索引 · 机器可读 · 持续维护',
    href: 'https://github.com/Anonymousyz/awesome-ai-production-readiness'
  }
];
---

<Layout
  title="Anonymousyz｜政策研究、AI 治理与开源工具"
  description="Anonymousyz 的个人专业主页，展示 AI 上线检查、研究转决策和生产级 AI 资源整理工具。"
>
  <header class="site-header shell">
    <a class="brand" href="#top" aria-label="返回首页">
      <span class="brand-mark">A</span>
      <span>Anonymousyz</span>
    </a>
    <nav aria-label="主导航">
      <a href="#work">工具</a>
      <a href="#why">为什么做</a>
      <a href="#about">关于我</a>
    </nav>
    <a class="header-link" href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
      GitHub <span aria-hidden="true">↗</span>
    </a>
  </header>

  <main id="top">
    <section class="hero shell">
      <div class="hero-copy">
        <p class="eyebrow"><span></span> 个人专业主页</p>
        <h1>我做政策和产业研究，<br /><em>也在做 AI 治理和开源工具。</em></h1>
        <p class="hero-lead">
          这里目前放着三个公开仓库，分别处理 AI 上线检查、研究资料转化和生产级 AI 资源整理。代码、说明和示例都可以直接查看。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#work">先看三个工具</a>
          <a class="button button-quiet" href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
            打开我的 GitHub <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <aside class="hero-panel" aria-label="网站内容说明">
        <div class="panel-topline">
          <span>你能在这里看到</span>
          <span class="status"><i></i> 个人主页</span>
        </div>
        <p class="panel-intro">这是公开作品入口，不是公司官网。</p>
        <div class="site-map">
          <div><strong>工具</strong><span>3 个已经公开的 GitHub 仓库</span></div>
          <div><strong>文章</strong><span>从个人知识库逐篇整理发布</span></div>
          <div><strong>案例</strong><span>只展示经过脱敏的公开版本</span></div>
        </div>
        <p class="panel-boundary">客户材料和内部项目不在这里公开。</p>
      </aside>
    </section>

    <section class="section shell" id="work">
      <div class="section-heading">
        <div>
          <p class="kicker">01 / 公开工具</p>
          <h2>目前能直接查看的三个工具</h2>
        </div>
        <p>它们对应我在研究和 AI 项目中反复遇到的三类问题。每个仓库都保留说明、源码和可检查的示例。</p>
      </div>

      <div class="project-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="card-index">{project.index}</div>
            <p class="project-question">{project.question}</p>
            <h3>{project.title}</h3>
            <p class="project-description">{project.description}</p>
            <p class="project-meta">{project.meta}</p>
            <a href={project.href} target="_blank" rel="noreferrer" aria-label={`打开 ${project.title}`}>
              打开 GitHub 仓库 <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section method-section" id="why">
      <div class="shell story-grid">
        <div>
          <p class="kicker">02 / 为什么做</p>
          <h2>这些工具解决的是同一个麻烦</h2>
        </div>
        <div class="story-copy">
          <p>
            研究项目和 AI 项目里经常有这种情况：材料并不少，系统也可能已经能运行，但关键判断仍然依赖少数人的经验，其他人很难复核。
          </p>
          <p>
            这三个仓库做的是同一件事。先把判断标准写清楚，再把其中可以重复检查的部分交给程序。涉及责任和取舍的结论，继续由人来做。
          </p>
          <p class="story-note">
            它们是公开方法和可运行原型，不是客户项目的公开版。
          </p>
        </div>
      </div>
    </section>

    <section class="section shell about" id="about">
      <div>
        <p class="kicker">03 / 关于我</p>
        <h2>我在做什么</h2>
      </div>
      <div class="about-copy">
        <p>
          我长期处理政策、产业和治理问题。现在，我也在研究企业采用 AI 时会碰到的证据、责任、数据和运行边界。
        </p>
        <p>
          Anonymousyz 是我的公开技术账号。这个网站只放可以公开、可以复用的部分，包括工具、文章和脱敏案例。
        </p>
        <a href="https://github.com/Anonymousyz" target="_blank" rel="noreferrer">
          查看 GitHub 公开档案 <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="shell">
      <div>
        <strong>Anonymousyz</strong>
        <span>政策研究 · AI 治理 · 开源工具</span>
      </div>
      <p>问题和建议可以通过 GitHub 联系。</p>
    </div>
  </footer>
</Layout>
